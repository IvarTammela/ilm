<IfModule mod_headers.c>
    Header always set Permissions-Policy "geolocation=(self)"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' https://tile.openstreetmap.org"
</IfModule>
